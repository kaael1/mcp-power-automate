{
  "name": "@mgabr90/mcp-power-automate",
  "version": "0.5.0-alpha.1",
  "private": false,
  "type": "module",
  "description": "Local MCP server and reusable skill bundle for Microsoft Power Automate with browser-backed auth, explicit flow targeting, validation, review diff, and rollback. Fork adds Power Platform Solutions and Environment Variable management via Dataverse Web API.",
  "mcpName": "io.github.mgabr90/mcp-power-automate",
  "bin": {
    "mcp-power-automate": "dist/server/index.js"
  },
  "files": [
    "dist",
    "assets",
    "skills",
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "server.json"
  ],
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mgabr90/mcp-power-automate.git"
  },
  "bugs": {
    "url": "https://github.com/Mgabr90/mcp-power-automate/issues"
  },
  "homepage": "https://github.com/Mgabr90/mcp-power-automate#readme",
  "license": "MIT",
  "keywords": [
    "automation",
    "ai-agents",
    "browser-extension",
    "browser-auth",
    "claude-code",
    "codex",
    "codex-skill",
    "cursor",
    "flow",
    "lobehub",
    "mcp",
    "microsoft-flow",
    "microsoft-power-automate",
    "model-context-protocol",
    "openclaw",
    "power-platform",
    "power-automate",
    "skill-bundle",
    "skills",
    "workflow-automation"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@toon-format/toon": "^2.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.27",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "postcss": "8.5.8",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
